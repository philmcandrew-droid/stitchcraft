# OpenRouter — AI pattern inspiration tab (image generation)
# Copy to ".env" in this folder (or edit the repo .env).
#
# Never commit a real key to git. `.env` is gitignored.
EXPO_PUBLIC_OPENROUTER_API_KEY=

# Preferred image model (tried first; app falls back through other image-output models if this fails).
# List: https://openrouter.ai/models?output_modalities=image — change slug if your account works better on OpenAI, etc.
EXPO_PUBLIC_OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# After changing any EXPO_PUBLIC_* value:
#   Dev:     npx expo start -c
#   Web:     npm run build:web
#   Android: npm run mobile:apk:release   (runs expo export + cap sync + release APK; same bake-in as web)
