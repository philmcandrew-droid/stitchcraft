# OpenRouter — AI pattern inspiration tab (image generation)
# Copy to ".env" in this folder and restart: npx expo start -c
#
# Never commit a real key. This key is bundled on web/native when prefixed with EXPO_PUBLIC_.
EXPO_PUBLIC_OPENROUTER_API_KEY=

# Optional: image model with output_modalities including "image"
# https://openrouter.ai/models?output_modalities=image
EXPO_PUBLIC_OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
